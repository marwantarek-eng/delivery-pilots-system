pipeline {
    agent any

    environment {
        AWS_REGION     = 'us-east-1'
        // ⚠️ حط رقم الـ AWS Account بتاعك مكان YOUR_AWS_ACCOUNT_ID هنا
        ECR_REGISTRY   = 'YOUR_AWS_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com'
        REPO_NAME      = 'order-svc'
        IMAGE_TAG      = "${BUILD_NUMBER}"
    }

    stages {
        stage('Lint & Test') {
            steps {
                dir('services/order-svc/app') {
                    print "Running python syntax checks..."
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('services/order-svc') {
                    script {
                        // قلبناها sh صريحة عشان الـ Podman يشتغل طلقة
                        sh "docker build -t ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG} ."
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    // سحب الـ Credentials اللي لسه عاملينها بإيدينا في جينكينز
                    withCredentials([string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                                     string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')]) {
                        
                        // تمرير المتغيرات للـ AWS CLI والـ Podman عشان يسجل دخول ويشحن
                        sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                        sh "docker push ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG}"
                        sh "docker tag ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG} ${ECR_REGISTRY}/${REPO_NAME}:latest"
                        sh "docker push ${ECR_REGISTRY}/${REPO_NAME}:latest"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully for Order Service!"
        }
        failure {
            echo "Pipeline failed. Check the logs."
        }
    }
}
