pipeline {
    agent any

    environment {
        AWS_REGION     = 'us-east-1'
        // ⚠️ حط رقم الـ AWS Account الحقيقي بتاعك هنا مكان الـ 123456789012
        ECR_REGISTRY   = '123456789012.dkr.ecr.us-east-1.amazonaws.com'
        REPO_NAME      = 'order-svc'
        IMAGE_TAG      = "${BUILD_NUMBER}"
    }

    stages {
        stage('Lint & Test') {
            steps {
                dir('services/order-svc/app') {
                    print "Running python syntax checks..."
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('services/order-svc') {
                    script {
                        // ضغط الفولدر وبنائه دايركت عبر الـ Socket باستخدام الـ URL الصحيح لتفادي بورت 80
                        sh """
                        tar -cf context.tar .
                        curl --unix-socket /var/run/docker.sock -H "Content-Type: application/x-tar" \
                          -X POST "http:/v1.40/build?t=${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG}" \
                          --data-binary @context.tar
                        rm -f context.tar
                        """
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    withCredentials([string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                                     string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')]) {
                        
                        sh """
                        TOKEN=\$(aws ecr get-login-password --region ${AWS_REGION})
                        
                        # تسجيل الدخول في الـ Podman بره عبر الـ Socket
                        curl --unix-socket /var/run/docker.sock -X POST -H "Content-Type: application/json" \
                          -d "{\\"username\\":\\"AWS\\",\\"password\\":\\"\${TOKEN}\\",\\"serveraddress\\":\\"https://${ECR_REGISTRY}\\"}" \
                          "http:/v1.40/auth"
                        
                        # عمل الـ Push طيران عبر الـ API
                        curl --unix-socket /var/run/docker.sock -X POST "http:/v1.40/images/${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG}/push"
                        
                        curl --unix-socket /var/run/docker.sock -X POST "http:/v1.40/images/${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG}/tag?repo=${ECR_REGISTRY}/${REPO_NAME}&tag=latest"
                        
                        curl --unix-socket /var/run/docker.sock -X POST "http:/v1.40/images/${ECR_REGISTRY}/${REPO_NAME}:latest/push"
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully for Order Service!"
        }
        failure {
            echo "Pipeline failed. Check the logs."
        }
    }
}
