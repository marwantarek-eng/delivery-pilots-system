pipeline {
    agent any

    environment {
        AWS_REGION     = 'us-east-1'
        // ⚠️ حط رقم الـ AWS Account بتاعك الحقيقي هنا مكان الـ 123456789012
        ECR_REGISTRY   = '123456789012.dkr.ecr.us-east-1.amazonaws.com'
        REPO_NAME      = 'order-svc'
        IMAGE_TAG      = "${BUILD_NUMBER}"
    }

    stages {
        stage('Lint & Test') {
            steps {
                dir('services/order-svc/app') {
                    print "Running python syntax checks..."
                }
            }
        }

        stage('Setup Podman CLI') {
            steps {
                script {
                    // بننزل الـ Podman Remote النظيف والجاهز للبيئة دي في ثانية واحدة ومن غير صلاحيات root
                    sh """
                    if [ ! -f ./podman ]; then
                        curl -fsSL -o podman.tar.gz https://github.com/containers/podman/releases/download/v4.7.2/podman-remote-static-linux_amd64.tar.gz
                        tar -xzf podman.tar.gz --strip-components=2
                        rm -f podman.tar.gz
                        chmod +x podman
                    fi
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('services/order-svc') {
                    script {
                        // البناء بالـ Binary النظيف طيران عبر السوكت
                        sh "../../podman --url unix:///var/run/docker.sock build -t ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG} ."
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    withCredentials([string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                                     string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')]) {
                        
                        // تسجيل الدخول والشحن لـ ECR رسمي وحاجة تشرح القلب
                        sh """
                        aws ecr get-login-password --region ${AWS_REGION} | ./podman --url unix:///var/run/docker.sock login --username AWS --password-stdin ${ECR_REGISTRY}
                        ./podman --url unix:///var/run/docker.sock push ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG}
                        ./podman --url unix:///var/run/docker.sock tag ${ECR_REGISTRY}/${REPO_NAME}:${IMAGE_TAG} ${ECR_REGISTRY}/${REPO_NAME}:latest
                        ./podman --url unix:///var/run/docker.sock push ${ECR_REGISTRY}/${REPO_NAME}:latest
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully for Order Service!"
        }
        failure {
            echo "Pipeline failed. Check the logs."
        }
    }
}
